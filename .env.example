# ============================================================
#  CONFIGURACIÓN GLOBAL  —  copia este archivo a `.env`
#  y rellena los valores. NUNCA commitees el .env real.
# ============================================================

# ----- OpenRouter (LLM + VLM: Gemini) -----------------------
# Consigue tu key en https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-v1-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# Modelo multimodal de Gemini vía OpenRouter (ve la imagen Y decide la acción)
OPENROUTER_MODEL=google/gemini-2.0-flash-001
# Opcionales que OpenRouter recomienda para ranking/atribución
OPENROUTER_SITE_URL=http://localhost:5173
OPENROUTER_SITE_NAME=Carrito RC Platform

# ----- MongoDB Atlas (historial de instrucciones) -----------
# Cadena de conexión de tu cluster en MongoDB Cloud (Atlas)
MONGODB_URI=mongodb+srv://usuario:password@cluster0.xxxxx.mongodb.net/?retryWrites=true&w=majority
MONGODB_DB=carrito_rc

# ----- Cámara IP del celular --------------------------------
# URL del stream MJPEG/snapshot que expone la app del celular.
# Ej. IP Webcam (Android): http://192.168.1.50:8080/shot.jpg  (snapshot)
#     o el stream:         http://192.168.1.50:8080/video
# Usamos el endpoint de SNAPSHOT (un frame JPEG) para el VLM.
CAMERA_SNAPSHOT_URL=http://192.168.1.50:8080/shot.jpg

# ----- micro-ROS / ROS2 -------------------------------------
# El ros2-bridge corre dentro de la red docker; el micro-ROS agent
# escucha en UDP 8888 y el ESP32 apunta a la IP del host.
MICRO_ROS_AGENT_PORT=8888
# Dominio DDS (debe coincidir entre el bridge y el agent)
ROS_DOMAIN_ID=0
# Tópico de velocidad que consume el ESP32
CMD_VEL_TOPIC=/cmd_vel

# ----- URLs internas de microservicios (red docker) ---------
# (normalmente NO hace falta cambiarlas: son los nombres de servicio)
VLM_SERVICE_URL=http://vlm-service:8000
LLM_SERVICE_URL=http://llm-service:8000
INSTRUCTION_SERVICE_URL=http://instruction-service:8000
ROS2_BRIDGE_URL=http://ros2-bridge:8000

# ----- Frontend ---------------------------------------------
# URL pública del API Gateway que el navegador va a consumir
VITE_API_GATEWAY_URL=http://localhost:8080
